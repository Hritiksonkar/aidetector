# FastAPI server
HOST=0.0.0.0
PORT=8000

# CORS
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_ORIGIN_REGEX=^http://(localhost|127\\.0\\.0\\.1):\\d+$

# MongoDB (optional)
# MONGO_URI=mongodb://127.0.0.1:27017
# MONGO_DB_NAME=aidetector

# Cloudinary (optional)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# If your network uses a proxy/custom CA and HTTPS downloads fail, you can disable SSL verify in dev.
# HTTP_VERIFY_SSL=0
# YTDLP_NO_CHECK_CERT=1
